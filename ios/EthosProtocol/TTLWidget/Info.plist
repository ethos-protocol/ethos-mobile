<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>TTL Vault Status</string>
	<key>CFBundleName</key>
	<string>TTLWidget</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundlePackageType</key>
	<string>XPC!</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>

	<!-- TTLWidget.swift's @main WidgetBundle is the extension's entry point;
	     no NSExtensionMainStoryboard/principal class needed for a SwiftUI/WidgetKit
	     extension declared this way (iOS 14+ convention). -->
	<key>NSExtension</key>
	<dict>
		<key>NSExtensionPointIdentifier</key>
		<string>com.apple.widgetkit-extension</string>
	</dict>

	<!-- Sources/Services/APIClient.swift is compiled into this extension target too
	     (see project.yml) and reads Bundle.main.object(forInfoDictionaryKey: "API_BASE_URL").
	     Bundle.main inside an extension process resolves to the EXTENSION's own bundle, not
	     the host app's, so this key must be set here as well and kept in sync with
	     ../EthosProtocol/Info.plist. -->
	<key>API_BASE_URL</key>
	<string>https://api.ethos-protocol.app/v1</string>
</dict>
</plist>
